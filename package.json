{
  "name": "@tui-sandbox/monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Mika Vilpas",
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive build",
    "dev": "pnpm --filter integration-tests dev",
    "format:check": "oxfmt --check",
    "preinstall": "npx only-allow pnpm",
    "knip": "knip",
    "lint": "oxlint",
    "markdownlint": "rumdl check",
    "test": "vitest",
    "tui": "pnpm --filter=library build && pnpm --filter integration-tests exec tui"
  },
  "devDependencies": {
    "@mikavilpas/oxfmt-config": "3.0.0",
    "@mikavilpas/oxlint-config": "3.0.0",
    "@types/node": "24.13.3",
    "cypress": "15.18.1",
    "eslint-plugin-import-zod": "1.2.1",
    "eslint-plugin-no-only-tests": "3.4.0",
    "knip": "6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  },
  "packageManager": "pnpm@11.15.1"
}
