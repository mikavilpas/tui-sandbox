{
  "name": "@tui-sandbox/monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Mika Vilpas",
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive build",
    "dev": "pnpm --filter integration-tests dev",
    "format:check": "oxfmt --check",
    "preinstall": "npx only-allow pnpm",
    "knip": "knip",
    "lint": "pnpx oxlint --type-aware --deny-warnings && eslint --max-warnings=0 .",
    "markdownlint": "rumdl check",
    "test": "vitest",
    "tui": "pnpm --filter=library build && pnpm --filter integration-tests exec tui"
  },
  "devDependencies": {
    "cypress": "15.18.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-import-zod": "1.2.1",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-oxlint": "1.72.0",
    "knip": "6.23.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.23.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  },
  "packageManager": "pnpm@11.9.0"
}
