{
  "name": "@tui-sandbox/library",
  "version": "13.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikavilpas/tui-sandbox"
  },
  "bin": {
    "tui": "bin/tui.js"
  },
  "files": [
    "bin",
    "dist",
    "src/server/cypress-support/tui-sandbox-template.ts"
  ],
  "type": "module",
  "main": "./dist/src/client/index.js",
  "types": "./dist/src/client/index.d.ts",
  "imports": {
    "#tui-sandbox-template": "./src/server/cypress-support/tui-sandbox-template.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/client/index.d.ts",
      "default": "./dist/src/client/index.js"
    },
    "./browser/neovim-client.js": {
      "types": "./dist/src/browser/neovim-client.d.ts",
      "default": "./dist/src/browser/neovim-client.js"
    },
    "./client": {
      "types": "./dist/src/client/index.d.ts",
      "default": "./dist/src/client/index.js"
    },
    "./server": {
      "types": "./dist/src/server/index.d.ts",
      "default": "./dist/src/server/index.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./dist/src/*"
  },
  "scripts": {
    "build": "concurrently --names 'vite,tsc' 'vite build' 'tsc' --prefix-colors blue,green && attw --pack --profile=esm-only",
    "dev": "concurrently --names 'client,server' 'pnpm dev:client' 'pnpm dev:server' --prefix-colors blue,green",
    "dev:client": "vite",
    "dev:server": "cd ../integration-tests/ && nodemon --watch ../library --ext '*' --exec 'tsx ../library/src/scripts/tui.ts start'",
    "test": "vitest"
  },
  "dependencies": {
    "@catppuccin/palette": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@xterm/addon-clipboard": "catalog:",
    "@xterm/addon-fit": "catalog:",
    "@xterm/addon-unicode11": "catalog:",
    "@xterm/xterm": "catalog:",
    "concurrently": "catalog:",
    "cors": "catalog:",
    "dree": "catalog:",
    "neovim": "catalog:",
    "sirv": "catalog:",
    "string-width": "catalog:",
    "tsx": "catalog:",
    "winston": "catalog:",
    "zigpty": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/cors": "catalog:",
    "@types/node": "catalog:",
    "cypress": "catalog:",
    "nodemon": "catalog:",
    "oxfmt": "catalog:",
    "prettier": "catalog:",
    "type-fest": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "cypress": "^13 || ^14 || ^15",
    "oxfmt": ">= 0.56.0",
    "prettier": ">= 3.3.3",
    "type-fest": ">= 4.27.0",
    "typescript": ">= 5.6.3",
    "wait-on": ">=9.0.0",
    "zod": ">=4.0.0-0 <5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
